{
  "name": "my-ink-components",
  "version": "1.0.0",
  "description": "Few small components to use in an Ink app.",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "esbuild index.tsx --bundle --platform=node --format=esm --jsx=automatic --external:react --external:ink --external:ink-scroll-view --external:@zenobius/ink-mouse --external:react-router --outfile=dist/index.js",
    "start": "cross-env DEV=true tsx --inspect ./example/index.jsx",
    "build-example": "node example/build.mjs"
  },
  "keywords": [
    "ink"
  ],
  "author": "Tadeusz Makuch <tadeusz.makuch@github.com>",
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "@zenobius/ink-mouse": "^1.0.3",
    "ink": "^7.0.1",
    "ink-scroll-view": "^0.3.6",
    "react": "^19.2.5",
    "react-router": "^7.14.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "postject": "^1.0.0-alpha.6",
    "react-devtools-core": "^7.0.1",
    "tsx": "^4.19.3",
    "prettier": "^3.8.3"
  }
}
